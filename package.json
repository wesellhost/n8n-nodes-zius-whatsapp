{
    "name": "n8n-nodes-zius-whatsapp",
    "version": "0.1.1",
    "description": "Advanced Zius WhatsApp integration for n8n",
    "license": "MIT",
    "homepage": "",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Ahmed Elsayed",
        "email": "sales@wesellhost.uk"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/wesellhost/n8n-nodes-zius-whatsapp"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/ZiusApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Zius/Zius.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/form-data": "^2.2.1",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "form-data": "^4.0.5"
    }
}